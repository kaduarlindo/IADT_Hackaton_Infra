# Variáveis de Ambiente

## AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

## Aplicação
PROJECT_NAME=hackaton-platform
ENVIRONMENT=dev
LOG_LEVEL=INFO

## DynamoDB
DYNAMODB_TABLE_NAME=hackaton-documents

## S3
S3_BUCKET_NAME=hackaton-uploads-{ACCOUNT_ID}

## API
API_ENDPOINT=https://api.example.com
API_STAGE=dev

## Frontend
REACT_APP_API_URL=https://api.example.com/dev

## Desenvolvimento Local
LOCAL_DYNAMODB_ENDPOINT=http://localhost:8000
LOCAL_S3_ENDPOINT=http://localhost:9000

## Logging
PYTHONUNBUFFERED=1
